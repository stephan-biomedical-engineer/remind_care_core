<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Relatório Médico - RemindCare</title>
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            color: #333;
            margin: 0;
            padding: 20px;
        }
        .header {
            text-align: center;
            border-bottom: 2px solid #2ecc71;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .header h1 {
            color: #2ecc71;
            margin: 0;
        }
        .header p {
            color: #7f8c8d;
            margin: 5px 0 0 0;
        }
        .patient-info {
            background-color: #f9f9f9;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 30px;
        }
        .patient-info h2 {
            margin-top: 0;
            font-size: 18px;
            color: #2c3e50;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }
        th {
            background-color: #2ecc71;
            color: white;
            font-weight: bold;
        }
        tr:nth-child(even) {
            background-color: #f2f2f2;
        }
        .adherence-good {
            color: #27ae60;
            font-weight: bold;
        }
        .adherence-bad {
            color: #e74c3c;
            font-weight: bold;
        }
        .footer {
            text-align: center;
            font-size: 12px;
            color: #bdc3c7;
            margin-top: 50px;
            border-top: 1px solid #eee;
            padding-top: 20px;
        }
    </style>
</head>
<body>

    <div class="header">
        <h1>RemindCare</h1>
        <p>Relatório de Adesão ao Tratamento</p>
        <p>Data de Emissão: <%= date %></p>
    </div>

    <div class="patient-info">
        <h2>Dados do Paciente</h2>
        <p><strong>Nome:</strong> <%= user.name %></p>
        <p><strong>E-mail:</strong> <%= user.email %></p>
    </div>

    <h2>Histórico de Medicações</h2>
    
    <% if (medicines.length === 0) { %>
        <p>Nenhuma medicação registrada para este paciente.</p>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>Medicamento</th>
                    <th>Dosagem</th>
                    <th>Compartimento</th>
                    <th>Horário</th>
                    <th>No Horário</th>
                    <th>Esquecidos</th>
                    <th>Atrasados</th>
                    <th>Adiantados</th>
                    <th>Taxa de Adesão</th>
                </tr>
            </thead>
            <tbody>
                <% medicines.forEach(function(med) { 
                    const onTime = parseInt(med.on_time_count);
                    const late = parseInt(med.late_count);
                    const warning = parseInt(med.warning_count);
                    const early = parseInt(med.early_count || 0);
                    const total = onTime + late + warning + early;
                    const rate = total > 0 ? Math.round((onTime / total) * 100) : 0;
                    const adherenceClass = rate >= 80 ? 'adherence-good' : (total > 0 ? 'adherence-bad' : '');
                    const timeStr = med.scheduled_time ? med.scheduled_time.substring(0, 5) : '-';
                %>
                <tr>
                    <td><strong><%= med.name %></strong></td>
                    <td><%= med.dosage %></td>
                    <td><%= med.compartment %></td>
                    <td><%= timeStr %></td>
                    <td><%= onTime %></td>
                    <td><%= late %></td>
                    <td><%= warning %></td>
                    <td><%= early %></td>
                    <td class="<%= adherenceClass %>">
                        <%= total > 0 ? rate + '%' : 'N/A' %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>

    <br>
    <h2>Histórico Detalhado (Todos os Registros)</h2>
    <% if (typeof recentLogs !== 'undefined' && recentLogs.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>Data e Hora</th>
                    <th>Medicamento</th>
                    <th>Situação</th>
                </tr>
            </thead>
            <tbody>
                <% recentLogs.forEach(function(log) { 
                    const logDate = new Date(log.opened_at).toLocaleString('pt-BR');
                    let sit = log.situation;
                    let sitClass = '';
                    if(sit === 'early') { sit = 'Adiantado'; sitClass = 'adherence-good'; }
                    else if(sit === 'onTime') { sit = 'No Horário'; sitClass = 'adherence-good'; }
                    else if(sit === 'warning') { sit = 'Atrasado'; sitClass = 'adherence-bad'; }
                    else if(sit === 'late') { sit = 'Muito Atrasado'; sitClass = 'adherence-bad'; }
                    else if(sit === 'missed') { sit = 'Esquecido'; sitClass = 'adherence-bad'; }
                %>
                <tr>
                    <td><%= logDate %></td>
                    <td><strong><%= log.medicine_name %></strong></td>
                    <td class="<%= sitClass %>"><%= sit %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>Nenhum evento registrado recentemente.</p>
    <% } %>

    <div class="footer">
        <p>Este é um documento gerado automaticamente pelo sistema RemindCare.</p>
        <p>Para dúvidas, contate o suporte.</p>
    </div>

</body>
</html>
